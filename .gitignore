# Dollar Hegemony — .gitignore


# Data files
# These are large and get regenerated by data_collector.py + feature_engineer.py
data/raw/
data/processed/


# Trained model artifacts
# Regenerate by running the model scripts
models/
*.pkl
*.keras
*.pt
*.h5
*.onnx
*.joblib


# MLflow experiment tracking
# mlruns/ gets created automatically when you run any model script
mlruns/
mlartifacts/
.mlflow/


# Generated outputs
# Charts and result CSVs are regenerated by model scripts
outputs/


# Secrets and environment variables
# Never commit credentials
.env
.env.*
!.env.example
secrets.py
config.local.*
*_credentials.*
*_key.txt
*_token.txt
dagshub.token


# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-wheel-metadata/
MANIFEST


# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/


# Jupyter notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints


# OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# IDE and editor files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~


# Docker
.docker/
docker-volumes/


# Logs and temp files
*.log
*.tmp
*.temp
logs/
temp/
tmp/


# DagsHub / DVC
# Only ignore the cache, not the config or .dvc pointer files
.dvc/tmp/
.dvc/cache/